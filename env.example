# LLM
GROQ_API_KEY=replace_me
GROQ_MODEL=llama-3.3-70b-versatile

# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=replace_me
CLERK_SECRET_KEY=replace_me
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
CLERK_WEBHOOK_SECRET=replace_me

# Database / Redis
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/database
SYNC_DATABASE_URL=postgresql://user:password@host:5432/database
REDIS_URL=redis://host:6379

# App URLs
API_BASE_URL=https://your-api-host.example
NEXT_PUBLIC_API_URL=https://your-api-host.example
NEXT_PUBLIC_WS_URL=wss://your-api-host.example/ws
NEXT_PUBLIC_APP_URL=https://your-frontend-host.example

# RAG / mocks
CHROMA_PERSIST_DIR=./chroma_db
EMBEDDING_MODEL=models/text-embedding-004
MOCK_GSTN_URL=https://gstn-xi.vercel.app/
MOCK_EPFO_URL=https://epfo-coral.vercel.app/
